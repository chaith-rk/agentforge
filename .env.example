# AgentForge Platform — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.

# Vapi Configuration
VAPI_API_KEY=your_vapi_api_key_here
VAPI_WEBHOOK_SECRET=your_webhook_secret_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
VAPI_SERVER_URL=https://your-domain.com/webhooks/vapi

# Database
# Local dev: relative path (data/calls.db)
# Production (Railway): mount a persistent volume and set DATABASE_PATH
# to a file inside that mount (e.g., /app/data/calls.db).
DATABASE_URL=sqlite+aiosqlite:///data/calls.db
DATABASE_PATH=data/calls.db

# API Security — generate a random string for production
API_KEY=your_dashboard_api_key_here

# Anthropic — used for post-call narrative summary on the report page.
# Optional: if unset, the summary section in the call report is omitted
# but the rest of the report renders normally.
ANTHROPIC_API_KEY=
SUMMARY_MODEL=claude-haiku-4-5-20251001

# CORS — allowed origins for the dashboard
CORS_ORIGINS=["http://localhost:3000"]

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development

# PII Encryption — generate with: python scripts/generate_encryption_key.py
PII_ENCRYPTION_KEY=generate_a_fernet_key_here

# WebSocket
WEBSOCKET_PING_INTERVAL=30

# Frontend environment variables — copy to .env.local for local dev
# or set these in Vercel project settings for production.

# Backend REST API base URL.
# Local dev (using Vite proxy): leave as /api
# Production (Vercel): https://<your-railway-domain>/api
VITE_API_BASE=/api

# Backend host for the WebSocket connection (no scheme — wss:// is auto-picked in prod).
# Local dev: leave empty, falls back to window.location.host with the Vite proxy.
# Production: <your-railway-domain>  (e.g., agentforge-backend.up.railway.app)
VITE_WS_HOST=

# Backend API key. Must match API_KEY set in Railway backend env vars.
# Sent in the X-API-Key header on every request.
VITE_API_KEY=
